# ─── Black Maria 2.0 — environment ───────────────────────────────────────────
# Everything here is OPTIONAL. With no env at all, the app runs on the local
# JSON file-store and a deterministic offline "crew" + stub generator.
# Set the Supabase + Anthropic vars to make it the hostable, production brain.

# ── Storage driver ───────────────────────────────────────────────────────────
# When BOTH of these are set, the Supabase Postgres driver activates and the
# file-store is bypassed. Get them from your Supabase project → Settings → API.
# (Service-role key is server-only — never expose it to the browser.)
NEXT_PUBLIC_SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ── Crew brain ───────────────────────────────────────────────────────────────
# When set, the Line Producer + Prop Master run on Claude. When absent, a
# deterministic offline fallback produces a believable breakdown so the demo
# works with zero keys.
ANTHROPIC_API_KEY=

# ── Generator backend ────────────────────────────────────────────────────────
# Reserved for the real image adapter (fal / Magnific / etc). The default
# "stub" adapter renders deterministic SVG stills so consistency is visible.
GENERATOR_BACKEND=stub
FAL_KEY=
